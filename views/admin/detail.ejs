<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">🏥</div>
                <div class="logo-text">
                    <h2>Laporan IKP</h2><span>Keselamatan Pasien</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-label">Admin</div>
                <a href="/admin/dashboard" class="nav-item"><span class="nav-icon">📊</span> Dashboard</a>
                <a href="/admin/laporan" class="nav-item active"><span class="nav-icon">📋</span> Daftar Laporan</a>
                <a href="/admin/users" class="nav-item"><span class="nav-icon">👥</span> Manajemen User</a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-avatar">
                    <%= user.name[0].toUpperCase() %>
                </div>
                <div class="user-info">
                    <div class="name">
                        <%= user.name %>
                    </div>
                    <div class="role">🛡️ Administrator</div>
                </div>
                <a href="/auth/logout" style="margin-left:auto;color:var(--danger);text-decoration:none;">🚪</a>
            </div>
        </aside>
        <main class="main-content">
            <div class="page-header">
                <div>
                    <a href="/admin/laporan" style="font-size:0.8rem;color:var(--text-muted);text-decoration:none;">←
                        Kembali ke Daftar</a>
                    <h1 style="margin-top:0.25rem">📄 Detail Laporan #<%= incident.id %>
                    </h1>
                </div>
                <div class="page-header-actions">
                    <% var gradingEmoji='🔵' ; if (incident.grading_risiko==='Merah' ) { gradingEmoji='🔴' ; } else if
                        (incident.grading_risiko==='Kuning' ) { gradingEmoji='🟡' ; } else if
                        (incident.grading_risiko==='Hijau' ) { gradingEmoji='🟢' ; } %>
                        <span class="badge badge-<%= incident.grading_risiko.toLowerCase() %>"
                            style="font-size:0.85rem;padding:0.4rem 0.9rem">
                            <%= gradingEmoji %> Grading <%= incident.grading_risiko %>
                        </span>
                        <span class="badge badge-<%= incident.status %>"
                            style="font-size:0.85rem;padding:0.4rem 0.9rem">
                            <%= incident.status %>
                        </span>
                        <% if (incident.is_final) { %>
                            <span class="badge"
                                style="background:var(--success-bg); color:var(--success); font-size:0.85rem; padding:0.4rem 0.9rem">✅
                                Final</span>
                            <% } else { %>
                                <span class="badge"
                                    style="background:var(--warning-bg); color:var(--warning); font-size:0.85rem; padding:0.4rem 0.9rem">✏️
                                    Draft</span>
                                <% } %>
                </div>
            </div>

            <% if (success && success.length> 0) { %>
                <div class="alert alert-success">✅ <%= success[0] %>
                </div>
                <% } %>
                    <% if (error && error.length> 0) { %>
                        <div class="alert alert-error">⚠️ <%= error[0] %>
                        </div>
                        <% } %>

                            <div class="card" style="margin-bottom:1.5rem;padding:1rem 1.5rem">
                                <form method="POST" action="/admin/laporan/<%= incident.id %>/status"
                                    style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap;">
                                    <label style="font-size:0.875rem;font-weight:600;color:var(--text-muted)">Update
                                        Status:</label>
                                    <select name="status" class="form-control" style="width:auto;">
                                        <option value="pending" <% if (incident.status==='pending' ) { %>selected<% } %>
                                                >
                                                ⏳ Pending</option>
                                        <option value="reviewed" <% if (incident.status==='reviewed' ) { %>selected<% }
                                                %>>
                                                ✅ Reviewed</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary btn-sm">Simpan Status</button>
                                    <% if (incident.is_final) { %>
                                        <small class="text-success" style="margin-left:auto">Laporan ini sudah
                                            dikonfirmasi FINAL oleh pelapor.</small>
                                        <% } else { %>
                                            <small class="text-warning" style="margin-left:auto">Laporan ini masih DRAFT
                                                (pelapor masih bisa mengedit hari ini).</small>
                                            <% } %>
                                </form>
                            </div>

                            <div class="form-section">
                                <div class="form-section-header">
                                    <div class="section-num">📋</div>
                                    <h2>Rincian Insiden</h2>
                                </div>
                                <div class="form-section-body">
                                    <div class="detail-grid">
                                        <div class="detail-item">
                                            <div class="di-label">Tanggal</div>
                                            <div class="di-value">
                                                <%= new Date(incident.tanggal_insiden).toLocaleDateString('id-ID',
                                                    {weekday:'long', year:'numeric', month:'long', day:'numeric'}) %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Waktu</div>
                                            <div class="di-value">
                                                <%= incident.waktu_insiden %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Jenis Insiden</div>
                                            <div class="di-value"><span
                                                    class="badge badge-<%= incident.jenis_insiden.toLowerCase() %>">
                                                    <%= incident.jenis_insiden %>
                                                </span></div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Akibat</div>
                                            <div class="di-value">
                                                <%= incident.akibat_insiden %>
                                            </div>
                                        </div>
                                        <div class="detail-item" style="grid-column:1/-1">
                                            <div class="di-label">Insiden</div>
                                            <div class="di-value">
                                                <%= incident.insiden %>
                                            </div>
                                        </div>
                                        <div class="detail-item" style="grid-column:1/-1">
                                            <div class="di-label">Kronologis</div>
                                            <div class="di-value" style="white-space:pre-line">
                                                <%= incident.kronologis %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Pelapor Pertama</div>
                                            <div class="di-value">
                                                <%= incident.pelapor_pertama %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Insiden Terjadi Pada</div>
                                            <div class="di-value">
                                                <%= incident.insiden_terjadi_pada %>
                                                    <% if (incident.insiden_terjadi_lainnya) { %> — <%=
                                                            incident.insiden_terjadi_lainnya %>
                                                            <% } %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Menyangkut Pasien</div>
                                            <div class="di-value">
                                                <%= incident.menyangkut_pasien %>
                                                    <% if (incident.menyangkut_lainnya) { %> — <%=
                                                            incident.menyangkut_lainnya %>
                                                            <% } %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Tempat Insiden</div>
                                            <div class="di-value">
                                                <%= incident.tempat_insiden %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Spesialisasi</div>
                                            <div class="di-value">
                                                <%= incident.spesialisasi %>
                                                    <% if (incident.spesialisasi_lainnya) { %> — <%=
                                                            incident.spesialisasi_lainnya %>
                                                            <% } %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Unit Terkait</div>
                                            <div class="di-value">
                                                <%= incident.unit_terkait %>
                                            </div>
                                        </div>
                                        <div class="detail-item" style="grid-column:1/-1">
                                            <div class="di-label">Tindakan Segera</div>
                                            <div class="di-value" style="white-space:pre-line">
                                                <%= incident.tindakan_segera %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Tindakan Oleh</div>
                                            <div class="di-value">
                                                <%= incident.tindakan_oleh %>
                                                    <% if (incident.tindakan_lainnya) { %> — <%=
                                                            incident.tindakan_lainnya %>
                                                            <% } %>
                                            </div>
                                        </div>
                                        <div class="detail-item">
                                            <div class="di-label">Kejadian Serupa?</div>
                                            <div class="di-value">
                                                <% if (incident.kejadian_serupa) { %>✅ Ya<% } else { %>❌ Tidak<% } %>
                                            </div>
                                        </div>
                                        <% if (incident.detail_serupa) { %>
                                            <div class="detail-item" style="grid-column:1/-1">
                                                <div class="di-label">Detail Kejadian Serupa</div>
                                                <div class="di-value" style="white-space:pre-line">
                                                    <%= incident.detail_serupa %>
                                                </div>
                                            </div>
                                            <% } %>
                                                <div class="detail-item">
                                                    <div class="di-label">Dilaporkan Oleh</div>
                                                    <div class="di-value">
                                                        <%= incident.pelapor_name || '-' %>
                                                    </div>
                                                </div>
                                                <div class="detail-item">
                                                    <div class="di-label">Dilaporkan Pada</div>
                                                    <div class="di-value">
                                                        <%= new Date(incident.created_at).toLocaleString('id-ID') %>
                                                    </div>
                                                </div>
                                                <% if (incident.pembuat_laporan_file) { %>
                                                    <div class="detail-item">
                                                        <div class="di-label">File Pembuat Laporan</div>
                                                        <div class="di-value"><a
                                                                href="/uploads/<%= incident.pembuat_laporan_file %>"
                                                                target="_blank" class="btn btn-secondary btn-sm">📎
                                                                Download File</a></div>
                                                    </div>
                                                    <% } %>
                                    </div>
                                    <% if (incident.tanda_tangan) { %>
                                        <hr class="divider">
                                        <div>
                                            <div class="di-label" style="margin-bottom:0.5rem">Tanda Tangan Digital
                                            </div>
                                            <div
                                                style="background:#111827;border-radius:8px;padding:0.5rem;display:inline-block;border:1px solid var(--border)">
                                                <img src="<%= incident.tanda_tangan %>"
                                                    style="max-width:400px;height:auto;display:block">
                                            </div>
                                        </div>
                                        <% } %>
                                </div>
                            </div>

                            <div class="form-section">
                                <div class="form-section-header">
                                    <div class="section-num">A</div>
                                    <h2>Data Pasien</h2>
                                </div>
                                <div class="form-section-body">
                                    <% if (patient) { %>
                                        <!-- Data Pasien sudah ada - tampilkan saja -->
                                        <div class="detail-grid">
                                            <div class="detail-item">
                                                <div class="di-label">Nama Pasien</div>
                                                <div class="di-value"><%= patient.nama_pasien %></div>
                                            </div>
                                            <div class="detail-item">
                                                <div class="di-label">No. Rekam Medik</div>
                                                <div class="di-value"><%= patient.no_rekam_medik %></div>
                                            </div>
                                            <div class="detail-item">
                                                <div class="di-label">Tanggal Lahir</div>
                                                <div class="di-value"><%= patient.tanggal_lahir ? new Date(patient.tanggal_lahir).toLocaleDateString('id-ID') : '-' %></div>
                                            </div>
                                            <div class="detail-item">
                                                <div class="di-label">Kelompok Umur</div>
                                                <div class="di-value"><%= patient.kelompok_umur && patient.kelompok_umur.trim() ? patient.kelompok_umur : '(kosong)' %></div>
                                            </div>
                                            <div class="detail-item">
                                                <div class="di-label">Jenis Kelamin</div>
                                                <div class="di-value">
                                                    <% if (patient.jenis_kelamin && patient.jenis_kelamin.trim()) { %>
                                                        <%= patient.jenis_kelamin === 'L' ? 'Laki-laki' : (patient.jenis_kelamin === 'P' ? 'Perempuan' : patient.jenis_kelamin) %>
                                                    <% } else { %>
                                                        (kosong)
                                                    <% } %>
                                                </div>
                                            </div>
                                            <div class="detail-item">
                                                <div class="di-label">Ruangan</div>
                                                <div class="di-value"><%= patient.ruangan || '-' %></div>
                                            </div>
                                            <div class="detail-item">
                                                <div class="di-label">Penanggung Biaya</div>
                                                <div class="di-value"><%= patient.penanggung_biaya || '-' %></div>
                                            </div>
                                            <div class="detail-item">
                                                <div class="di-label">Tanggal Masuk RS</div>
                                                <div class="di-value"><%= patient.tanggal_masuk ? new Date(patient.tanggal_masuk).toLocaleString('id-ID') : '-' %></div>
                                            </div>
                                            <div class="detail-item" style="grid-column: 1/-1;">
                                                <div class="di-label">Alamat</div>
                                                <div class="di-value"><%= patient.alamat || '-' %></div>
                                            </div>
                                        </div>
                                    <% } else { %>
                                        <!-- Belum ada data pasien -->
                                        <div class="alert alert-warning">⚠️ Pelapor belum melengkapi data pasien. Laporan ini masih dalam proses.</div>
                                    <% } %>
                                </div>
                            </div>
        </main>
    </div>
    </script>
</body>

</html>