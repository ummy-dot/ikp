<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">🏥</div>
                <div class="logo-text">
                    <h2>Laporan IKP</h2><span>Keselamatan Pasien</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-label">Admin</div>
                <a href="/admin/dashboard" class="nav-item"><span class="nav-icon">📊</span> Dashboard</a>
                <a href="/admin/laporan" class="nav-item active"><span class="nav-icon">📋</span> Daftar Laporan</a>
                <a href="/admin/users" class="nav-item"><span class="nav-icon">👥</span> Manajemen User</a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-avatar">
                    <%= user.name[0].toUpperCase() %>
                </div>
                <div class="user-info">
                    <div class="name">
                        <%= user.name %>
                    </div>
                    <div class="role">🛡️ Administrator</div>
                </div>
                <a href="/auth/logout" style="margin-left:auto;color:var(--danger);text-decoration:none;">🚪</a>
            </div>
        </aside>
        <main class="main-content">
            <div class="page-header">
                <div>
                    <h1>📋 Daftar Laporan Insiden</h1>
                    <p>Kelola dan tinjau semua laporan insiden keselamatan pasien</p>
                </div>
                <div class="page-header-actions">
                    <% 
                        const exportQuery = `grading=${filters.grading || ''}&jenis=${filters.jenis || ''}&status=${filters.status || ''}&q=${filters.q || ''}&final=${filters.final || ''}&date_from=${filters.date_from || ''}&date_to=${filters.date_to || ''}`;
                    %>
                    <a href="/admin/laporan/export-all?<%= exportQuery %>" class="btn btn-secondary" style="background: #4f46e5; color: white; border: none;">📥 Export PDF</a>
                    <a href="/admin/laporan/export-csv?<%= exportQuery %>" class="btn btn-success">📥 Export CSV</a>
                </div>
            </div>

            <form method="GET" action="/admin/laporan" class="filter-bar">
                <div class="form-group"><label>Cari</label><input type="text" name="q" class="form-control"
                        placeholder="Insiden / Unit..." value="<%= filters.q || '' %>"></div>
                <div class="form-group">
                    <label>Konfirmasi</label>
                    <select name="final" class="form-control">
                        <option value="">Semua</option>
                        <option value="1" <%=filters.final==='1' ? 'selected' : '' %>>✅ Final</option>
                        <option value="0" <%=filters.final==='0' ? 'selected' : '' %>>✏️ Draft</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Jenis</label>
                    <select name="jenis" class="form-control">
                        <option value="">Semua</option>
                        <% ['KNC','KTC','KPC','KTD','SENTINEL'].forEach(j=> { %>
                            <option value="<%= j %>" <%=filters.jenis===j ? 'selected' : '' %>><%= j %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>Grading</label>
                    <select name="grading" class="form-control">
                        <option value="">Semua</option>
                        <% ['Biru','Hijau','Kuning','Merah'].forEach(g=> { %>
                            <option value="<%= g %>" <%=filters.grading===g ? 'selected' : '' %>><%= g %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <select name="status" class="form-control">
                        <option value="">Semua</option>
                        <option value="pending" <%=filters.status==='pending' ? 'selected' : '' %>>Pending</option>
                        <option value="reviewed" <%=filters.status==='reviewed' ? 'selected' : '' %>>Reviewed</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Rentang Tanggal</label>
                    <div style="display: flex; border: 1px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; background: var(--bg-input);">
                        <input type="date" name="date_from" style="flex: 1; border: none; padding: 0.5rem 0.75rem; background: transparent; border-right: 1px solid var(--border); color: var(--text); font-size: 0.95rem;" value="<%= filters.date_from || '' %>">
                        <span style="padding: 0.5rem 0.75rem; color: var(--text-muted); display: flex; align-items: center;">s/d</span>
                        <input type="date" name="date_to" style="flex: 1; border: none; padding: 0.5rem 0.75rem; background: transparent; color: var(--text); font-size: 0.95rem;" value="<%= filters.date_to || '' %>">
                    </div>
                </div>
                <div style="display: flex; gap: 0.5rem; margin-top: auto;">
                    <button type="submit" class="btn btn-primary" style="flex: 1;">🔍 Filter</button>
                </div>
            </form>

            <% if (incidents.length===0) { %>
                <div class="card">
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <p>Tidak ada laporan ditemukan.</p>
                    </div>
                </div>
                <% } else { %>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Tanggal & Waktu</th>
                                    <th>Insiden</th>
                                    <th>Konfirmasi</th>
                                    <th>Jenis</th>
                                    <th>Grading</th>
                                    <th>Status</th>
                                    <th>Aksi</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% incidents.forEach((inc, i)=> { %>
                                    <span class="badge badge-<%= inc.jenis_insiden.toLowerCase() %>">
                                        <td>
                                            <%= i + 1 %>
                                        </td>
                                        <td>
                                            <div style="font-weight:500">
                                                <%= new Date(inc.tanggal_insiden).toLocaleDateString('id-ID',
                                                    {day:'2-digit',month:'short',year:'numeric'}) %>
                                            </div>
                                            <small class="text-muted">
                                                <%= inc.waktu_insiden %>
                                            </small>
                                        </td>
                                        <td style="max-width:200px">
                                            <div
                                                style="font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                                <%= inc.insiden %>
                                            </div>
                                            <small class="text-muted">
                                                <%= inc.unit_terkait %>
                                            </small>
                                        </td>
                                        <td>
                                            <% if (inc.is_final) { %>
                                                <span class="badge"
                                                    style="background:var(--success-bg); color:var(--success)">✅
                                                    Final</span>
                                                <% } else { %>
                                                    <span class="badge"
                                                        style="background:var(--warning-bg); color:var(--warning)">✏️
                                                        Draft</span>
                                                    <% } %>
                                        </td>
                                        <td><span class="badge badge-<%= inc.jenis_insiden.toLowerCase() %>">
                                                <%= inc.jenis_insiden %>
                                            </span></td>
                                        <td>
                                            <span class="badge badge-<%= inc.grading_risiko.toLowerCase() %>">
                                                <%= inc.grading_risiko==='Biru' ?'🔵':inc.grading_risiko==='Hijau'
                                                    ?'🟢':inc.grading_risiko==='Kuning' ?'🟡':'🔴' %>
                                                    <%= inc.grading_risiko %>
                                            </span>
                                        </td>
                                        <td><span class="badge badge-<%= inc.status %>">
                                                <%= inc.status %>
                                            </span></td>
                                        <td><a href="/admin/laporan/<%= inc.id %>" class="btn btn-secondary btn-sm">👁️
                                                Detail</a></td>
                                        </tr>
                                        <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </main>
    </div>
</body>

</html>