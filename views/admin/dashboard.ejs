<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>
    <div class="app-wrapper">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">🏥</div>
                <div class="logo-text">
                    <h2>Laporan IKP</h2><span>Keselamatan Pasien</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-label">Admin</div>
                <a href="/admin/dashboard" class="nav-item active"><span class="nav-icon">📊</span> Dashboard</a>
                <a href="/admin/laporan" class="nav-item"><span class="nav-icon">📋</span> Daftar Laporan</a>
                <a href="/admin/users" class="nav-item"><span class="nav-icon">👥</span> Manajemen User</a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-avatar">
                    <%= user.name[0].toUpperCase() %>
                </div>
                <div class="user-info">
                    <div class="name">
                        <%= user.name %>
                    </div>
                    <div class="role">🛡️ Administrator</div>
                </div>
                <a href="/auth/logout" style="margin-left:auto;color:var(--danger);text-decoration:none;">🚪</a>
            </div>
        </aside>

        <!-- MAIN -->
        <main class="main-content">
            <div class="page-header">
                <div>
                    <h1>📊 Dashboard</h1>
                    <p>Ringkasan laporan insiden keselamatan pasien</p>
                </div>
                <div class="page-header-actions">
                    <span style="font-size:0.8rem;color:var(--text-muted)">📅 <%= new
                            Date().toLocaleDateString('id-ID',{weekday:'long',year:'numeric',month:'long',day:'numeric'})
                            %></span>
                </div>
            </div>

            <!-- STAT CARDS -->
            <div class="stats-grid">
                <div class="stat-card" style="--card-accent:#14b8a6; --card-bg-icon:rgba(20,184,166,0.15)">
                    <div class="stat-icon">📋</div>
                    <div class="stat-info">
                        <div class="value">
                            <%= stats.total %>
                        </div>
                        <div class="label">Total Laporan</div>
                    </div>
                </div>
                <div class="stat-card" style="--card-accent:#f59e0b; --card-bg-icon:rgba(245,158,11,0.15)">
                    <div class="stat-icon">⏳</div>
                    <div class="stat-info">
                        <div class="value">
                            <%= stats.pending %>
                        </div>
                        <div class="label">Menunggu Review</div>
                    </div>
                </div>
                <div class="stat-card" style="--card-accent:#22c55e; --card-bg-icon:rgba(34,197,94,0.15)">
                    <div class="stat-icon">✅</div>
                    <div class="stat-info">
                        <div class="value">
                            <%= stats.reviewed %>
                        </div>
                        <div class="label">Sudah Direview</div>
                    </div>
                </div>

                <% const gradingColors={ Merah: '#ef4444' , Kuning: '#f59e0b' , Hijau: '#22c55e' , Biru: '#3b82f6' }; if
                    (stats.byGrading && stats.byGrading.length> 0) {
                    stats.byGrading.forEach(g => {
                    %>
                    <div class="stat-card"
                        style="--card-accent:<%= gradingColors[g.grading_risiko] || '#94a3b8' %>; --card-bg-icon:rgba(148,163,184,0.1)">
                        <div class="stat-icon">
                            <% if (g.grading_risiko==='Merah' ) { %>🔴<% } else if (g.grading_risiko==='Kuning' ) { %>🟡
                                    <% } else if (g.grading_risiko==='Hijau' ) { %>🟢<% } else { %>🔵<% } %>
                        </div>
                        <div class="stat-info">
                            <div class="value">
                                <%= g.count %>
                            </div>
                            <div class="label">Grading <%= g.grading_risiko %>
                            </div>
                        </div>
                    </div>
                    <% }); } %>
            </div>

            <!-- CHARTS ROW 1 -->
            <div class="charts-grid">
                <div class="chart-card">
                    <h3>📈 Laporan per Bulan</h3>
                    <div class="chart-wrapper"><canvas id="chartMonth"></canvas></div>
                </div>
                <div class="chart-card">
                    <h3>🏷️ Distribusi Jenis Insiden</h3>
                    <div class="chart-wrapper"><canvas id="chartJenis"></canvas></div>
                </div>
            </div>

            <!-- CHARTS ROW 2 -->
            <div class="charts-grid">
                <div class="chart-card">
                    <h3>🎨 Grading Risiko</h3>
                    <div class="chart-wrapper"><canvas id="chartGrading"></canvas></div>
                </div>
                <div class="chart-card">
                    <h3>⚕️ Akibat Insiden terhadap Pasien</h3>
                    <div class="chart-wrapper"><canvas id="chartAkibat"></canvas></div>
                </div>
            </div>

            <!-- RECENT LAPORAN -->
            <div class="card">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
                    <h3
                        style="font-size:0.9rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em">
                        ⏰ Laporan Terbaru</h3>
                    <a href="/admin/laporan" class="btn btn-secondary btn-sm">Lihat Semua →</a>
                </div>
                <% if (stats.total===0) { %>
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <p>Belum ada laporan masuk.</p>
                    </div>
                    <% } else { %>
                        <p class="text-muted" style="font-size:0.85rem">Total <strong>
                                <%= stats.total %>
                            </strong> laporan. Klik <a href="/admin/laporan" style="color:var(--primary)">Daftar
                                Laporan</a> untuk melihat detail.</p>
                        <% } %>
            </div>
        </main>
    </div>

    <script>
        // Data dari server - PERBAIKAN: pisahkan tag EJS
        const statsJson = '<%- JSON.stringify(stats).replace(/\\/g, "\\\\") %>';
        let statsFromServer;
        try {
            statsFromServer = JSON.parse(statsJson);
            console.log('Data dari server:', statsFromServer);
        } catch (e) {
            console.error('Gagal parse JSON:', e);
            statsFromServer = { total: 0, pending: 0, reviewed: 0, byMonth: [], byJenis: [], byGrading: [], byAkibat: [] };
        }

        // Inisialisasi chart setelah DOM siap
        document.addEventListener('DOMContentLoaded', function () {
            const chartDefaults = {
                color: '#94a3b8',
                plugins: {
                    legend: {
                        labels: {
                            color: '#94a3b8',
                            font: { family: 'Inter' }
                        }
                    }
                },
                scales: {
                    x: {
                        ticks: { color: '#64748b' },
                        grid: { color: 'rgba(51,65,85,0.4)' }
                    },
                    y: {
                        ticks: { color: '#64748b' },
                        grid: { color: 'rgba(51,65,85,0.4)' },
                        beginAtZero: true
                    }
                }
            };

            // Chart: per bulan
            try {
                const monthData = statsFromServer.byMonth || [];
                console.log('Data bulanan:', monthData);

                if (monthData.length > 0) {
                    new Chart(document.getElementById('chartMonth'), {
                        type: 'line',
                        data: {
                            labels: monthData.map(d => d.bulan),
                            datasets: [{
                                label: 'Laporan',
                                data: monthData.map(d => d.count),
                                borderColor: '#14b8a6',
                                backgroundColor: 'rgba(20,184,166,0.15)',
                                tension: 0.4,
                                fill: true,
                                pointBackgroundColor: '#14b8a6',
                                pointRadius: 4
                            }]
                        },
                        options: { ...chartDefaults, responsive: true, maintainAspectRatio: false }
                    });
                } else {
                    document.getElementById('chartMonth').parentElement.innerHTML = '<p style="text-align:center;color:gray">Tidak ada data bulanan</p>';
                }
            } catch (e) {
                console.error('Error chart bulanan:', e);
            }

            // Chart: jenis insiden
            try {
                const jenisData = statsFromServer.byJenis || [];
                console.log('Data jenis:', jenisData);

                const jenisColors = { KNC: '#818cf8', KTC: '#f59e0b', KPC: '#22c55e', KTD: '#ef4444', SENTINEL: '#c084fc' };

                if (jenisData.length > 0) {
                    new Chart(document.getElementById('chartJenis'), {
                        type: 'bar',
                        data: {
                            labels: jenisData.map(d => d.jenis_insiden),
                            datasets: [{
                                label: 'Jumlah',
                                data: jenisData.map(d => d.count),
                                backgroundColor: jenisData.map(d => jenisColors[d.jenis_insiden] || '#94a3b8'),
                                borderRadius: 6,
                                borderSkipped: false
                            }]
                        },
                        options: { ...chartDefaults, responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
                    });
                }
            } catch (e) {
                console.error('Error chart jenis:', e);
            }

            // Chart: grading (doughnut)
            try {
                const gradingData = statsFromServer.byGrading || [];
                console.log('Data grading:', gradingData);

                const gradingColors = { Biru: '#3b82f6', Hijau: '#22c55e', Kuning: '#f59e0b', Merah: '#ef4444' };

                if (gradingData.length > 0) {
                    new Chart(document.getElementById('chartGrading'), {
                        type: 'doughnut',
                        data: {
                            labels: gradingData.map(d => d.grading_risiko),
                            datasets: [{
                                data: gradingData.map(d => d.count),
                                backgroundColor: gradingData.map(d => gradingColors[d.grading_risiko] || '#94a3b8'),
                                borderWidth: 2,
                                borderColor: '#1e293b',
                                hoverOffset: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    labels: {
                                        color: '#94a3b8',
                                        font: { family: 'Inter' }
                                    }
                                }
                            }
                        }
                    });
                }
            } catch (e) {
                console.error('Error chart grading:', e);
            }

            // Chart: akibat (horizontal bar)
            try {
                const akibatData = statsFromServer.byAkibat || [];
                console.log('Data akibat:', akibatData);

                const akibatColors = ['#ef4444', '#f97316', '#f59e0b', '#22c55e', '#14b8a6'];

                if (akibatData.length > 0) {
                    new Chart(document.getElementById('chartAkibat'), {
                        type: 'bar',
                        data: {
                            labels: akibatData.map(d => d.akibat_insiden),
                            datasets: [{
                                label: 'Jumlah',
                                data: akibatData.map(d => d.count),
                                backgroundColor: akibatColors,
                                borderRadius: 6
                            }]
                        },
                        options: {
                            indexAxis: 'y',
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                x: {
                                    ticks: { color: '#64748b' },
                                    grid: { color: 'rgba(51,65,85,0.4)' },
                                    beginAtZero: true
                                },
                                y: {
                                    ticks: { color: '#94a3b8', font: { size: 11 } },
                                    grid: { display: false }
                                }
                            }
                        }
                    });
                }
            } catch (e) {
                console.error('Error chart akibat:', e);
            }
        });
    </script>