<% // Set layout and path for EJS body='' ; %>
    <!DOCTYPE html>
    <html lang="id">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
            <%= title %>
        </title>
        <link rel="stylesheet" href="/css/style.css">
        <link rel="icon"
            href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏥</text></svg>">
    </head>

    <body class="auth-page">

        <div class="auth-container animate-slideUp">
            <div class="auth-logo">
                <div class="logo-icon-big">🏥</div>
                <h1>Selamat Datang</h1>
                <p>Sistem Laporan Insiden Keselamatan Pasien</p>
            </div>

            <% if (error && error.length> 0) { %>
                <div class="alert alert-error">⚠️ <%= error[0] %>
                </div>
                <% } %>
                    <% if (success && success.length> 0) { %>
                        <div class="alert alert-success">✅ <%= success[0] %>
                        </div>
                        <% } %>

                            <form method="POST" action="/auth/login">
                                <div class="form-group mb-2">
                                    <label>Username <span class="required">*</span></label>
                                    <input type="text" name="username" class="form-control" placeholder="username Anda"
                                        required autofocus>
                                </div>
                                <div class="form-group mb-2">
                                    <label>Password <span class="required">*</span></label>
                                    <input type="password" name="password" id="loginPass" class="form-control"
                                        placeholder="••••••••" required>
                                    <div style="text-align:right; margin-top:0.25rem;">
                                        <button type="button" onclick="togglePass('loginPass',this)"
                                            style="background:none;border:none;color:var(--text-muted);font-size:0.75rem;cursor:pointer;">Tampilkan</button>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary btn-lg"
                                    style="width:100%; margin-top:0.5rem; justify-content:center;">
                                    🔐 Masuk
                                </button>
                            </form>

                            <div
                                style="text-align:center; margin-top:1.5rem; font-size:0.85rem; color:var(--text-muted);">
                                Belum punya akun? <a href="/auth/register" style="color:var(--primary);">Daftar di
                                    sini</a>
                            </div>
        </div>

        <script>
            function togglePass(id, btn) {
                const inp = document.getElementById(id);
                if (inp.type === 'password') { inp.type = 'text'; btn.textContent = 'Sembunyikan'; }
                else { inp.type = 'password'; btn.textContent = 'Tampilkan'; }
            }
        </script>
    </body>

    </html>