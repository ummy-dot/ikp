<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard User - IKP</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        body {
            display: flex;
            min-height: 100vh;
        }



        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .dashboard-header h1 {
            font-size: 28px;
            color: var(--text);
            margin: 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--bg);
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 1px 3px var(--shadow);
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            box-shadow: 0 4px 6px var(--shadow);
        }

        .stat-label {
            color: #64748b;
            font-size: 14px;
            margin-bottom: 8px;
            text-transform: uppercase;
            font-weight: 600;
        }

        .stat-value {
            color: var(--primary);
            font-size: 32px;
            font-weight: 700;
        }

        .chart-container {
            background: var(--bg);
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 30px;
            box-shadow: 0 1px 3px var(--shadow);
            position: relative;
            height: 400px;
        }

        .chart-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 20px;
            display: flex;
            align-items: center;
        }

        .chart-title::before {
            content: '📊';
            margin-right: 10px;
        }

        .no-data {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: #94a3b8;
            font-size: 16px;
        }

        @media (max-width: 768px) {
            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
                border-right: none;
                border-bottom: 1px solid #e2e8f0;
                padding: 15px;
            }

            .main-content {
                margin-left: 0;
                padding: 15px;
            }

            .sidebar-nav {
                flex-direction: row;
                flex-wrap: wrap;
            }

            .nav-item {
                flex: 1;
                min-width: 150px;
            }
        }
    </style>
</head>
<body>
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">🏥</div>
                <div class="logo-text">
                    <h2>Laporan IKP</h2><span>Keselamatan Pasien</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-label">Pelapor</div>
                <a href="/user/dashboard" class="nav-item active"><span class="nav-icon">📊</span> Dashboard</a>
                <a href="/user/form" class="nav-item"><span class="nav-icon">📝</span> Buat Laporan</a>
                <a href="/user/riwayat" class="nav-item"><span class="nav-icon">🕐</span> Riwayat Laporan</a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-avatar">
                    <%= user ? user.name[0].toUpperCase() : '?' %>
                </div>
                <div class="user-info">
                    <div class="name">
                        <%= user ? user.name : '-' %>
                    </div>
                    <div class="role">👤 Pelapor</div>
                </div>
                <a href="/auth/logout" style="margin-left:auto;color:var(--danger);text-decoration:none;">🚪</a>
            </div>
        </aside>

    <div class="main-content">
        <div class="dashboard-container">
            <div class="dashboard-header">
                <div>
                    <h1>Dashboard Laporan</h1>
                    <p style="color: #64748b; margin: 5px 0 0;">Pantau aktivitas pelaporan Anda</p>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Total Laporan</div>
                    <div class="stat-value"><%= totalReports %></div>
                </div>
                <% if (lastReport) { %>
                    <div class="stat-card">
                        <div class="stat-label">Laporan Terakhir</div>
                        <div class="stat-value" style="font-size: 16px;">
                            <%= new Date(lastReport).toLocaleDateString('id-ID') %>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Chart -->
            <div class="chart-container">
                <div class="chart-title">LAPORAN PER BULAN</div>
                <%
                    const data = JSON.parse(chartData);
                    if (data.labels && data.labels.length > 0) {
                %>
                    <canvas id="monthlyChart" style="position: relative; height: 350px;"></canvas>
                <% } else { %>
                    <div class="no-data">Belum ada laporan. Mulai buat laporan untuk melihat grafik.</div>
                <% } %>
            </div>
        </div>
    </div>

    <% if (chartData && JSON.parse(chartData).labels && JSON.parse(chartData).labels.length > 0) { %>
        <script>
            const chartData = <%- chartData %>;
            
            const ctx = document.getElementById('monthlyChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: chartData.labels,
                    datasets: [{
                        label: 'Laporan',
                        data: chartData.data,
                        borderColor: '#14b8a6',
                        backgroundColor: 'rgba(20, 184, 166, 0.05)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointRadius: 6,
                        pointBackgroundColor: '#14b8a6',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointHoverRadius: 8,
                        pointHoverBackgroundColor: '#0d9488'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            labels: {
                                color: '#64748b',
                                font: {
                                    size: 12,
                                    weight: '500'
                                },
                                usePointStyle: true,
                                padding: 20
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            padding: 12,
                            titleFont: {
                                size: 13,
                                weight: 'bold'
                            },
                            bodyFont: {
                                size: 12
                            },
                            callbacks: {
                                label: function(context) {
                                    return 'Laporan: ' + context.parsed.y;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: Math.max(...chartData.data) + 1,
                            ticks: {
                                stepSize: 0.1,
                                color: '#94a3b8',
                                font: {
                                    size: 11
                                }
                            },
                            grid: {
                                color: '#e2e8f0',
                                drawBorder: false
                            }
                        },
                        x: {
                            ticks: {
                                color: '#64748b',
                                font: {
                                    size: 11
                                }
                            },
                            grid: {
                                display: false
                            }
                        }
                    }
                }
            });
        </script>
    <% } %>
</body>
</html>
