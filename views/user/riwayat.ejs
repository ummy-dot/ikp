<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">🏥</div>
                <div class="logo-text">
                    <h2>Laporan IKP</h2><span>Keselamatan Pasien</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-label">Pelapor</div>
                <a href="/user/dashboard" class="nav-item"><span class="nav-icon">📊</span> Dashboard</a>
                <a href="/user/form" class="nav-item"><span class="nav-icon">📝</span> Buat Laporan</a>
                <a href="/user/riwayat" class="nav-item active"><span class="nav-icon">🕐</span> Riwayat Laporan</a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-avatar">
                    <%= user.name[0].toUpperCase() %>
                </div>
                <div class="user-info">
                    <div class="name">
                        <%= user.name %>
                    </div>
                    <div class="role">👤 Pelapor</div>
                </div>
                <a href="/auth/logout" style="margin-left:auto;color:var(--danger);text-decoration:none;">🚪</a>
            </div>
        </aside>
        <main class="main-content">
            <div class="page-header">
                <div>
                    <h1>🕐 Riwayat Laporan Saya</h1>
                    <p>Daftar laporan insiden yang Anda buat</p>
                </div>
                <div class="page-header-actions"><a href="/user/form" class="btn btn-primary">➕ Buat Laporan Baru</a>
                </div>
            </div>

            <% if (success && success.length> 0) { %><div class="alert alert-success">✅ <%= success[0] %>
                </div>
                <% } %>
                    <% if (error && error.length> 0) { %><div class="alert alert-error">⚠️ <%= error[0] %>
                        </div>
                        <% } %>

                            <% if (incidents.length===0) { %>
                                <div class="card">
                                    <div class="empty-state">
                                        <div class="empty-icon">📋</div>
                                        <h3>Belum Ada Laporan</h3>
                                        <p>Anda belum memiliki laporan insiden. Klik tombol di atas untuk membuat
                                            laporan baru.</p>
                                    </div>
                                </div>
                                <% } else { %>
                                    <div class="table-wrapper">
                                        <table>
                                            <thead>
                                                <tr>
                                                    <th>#</th>
                                                    <th>Tanggal</th>
                                                    <th>Insiden</th>
                                                    <th>Konfirmasi</th>
                                                    <th>Grading</th>
                                                    <th>Status Review</th>
                                                    <th>Aksi</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% incidents.forEach((inc, i)=> { %>
                                                    <tr>
                                                        <td>
                                                            <%= i + 1 %>
                                                        </td>
                                                        <td>
                                                            <div>
                                                                <%= new
                                                                    Date(inc.tanggal_insiden).toLocaleDateString('id-ID',
                                                                    {day:'2-digit',month:'short',year:'numeric'}) %>
                                                            </div>
                                                            <small class="text-muted">
                                                                <%= inc.waktu_insiden %>
                                                            </small>
                                                        </td>
                                                        <td style="max-width:200px">
                                                            <div
                                                                style="font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                                                <%= inc.insiden %>
                                                            </div>
                                                            <small class="text-muted">
                                                                <%= inc.unit_terkait %>
                                                            </small>
                                                        </td>
                                                        <td>
                                                            <% if (inc.is_final) { %>
                                                                <span class="badge"
                                                                    style="background:var(--success-bg); color:var(--success)">✅
                                                                    Final</span>
                                                                <% } else { %>
                                                                    <span class="badge"
                                                                        style="background:var(--warning-bg); color:var(--warning)">✏️
                                                                        Draft</span>
                                                                    <% } %>
                                                        </td>
                                                        <td>
                                                            <span
                                                                class="badge badge-<%= inc.grading_risiko.toLowerCase() %>">
                                                                <%= inc.grading_risiko==='Biru' ? '🔵' :
                                                                    inc.grading_risiko==='Hijau' ? '🟢' :
                                                                    inc.grading_risiko==='Kuning' ? '🟡' : '🔴' %>
                                                                    <%= inc.grading_risiko %>
                                                            </span>
                                                        </td>
                                                        <td><span class="badge badge-<%= inc.status %>">
                                                                <%= inc.status %>
                                                            </span></td>
                                                        <td>
                                                            <div style="display:flex; gap:0.5rem; align-items:center">
                                                                <a href="/user/form/<%= inc.id %>/detail"
                                                                    class="btn btn-secondary btn-sm"
                                                                    title="Lihat Detail">👁️ Detail</a>
                                                                <% if (!inc.is_final && inc.is_today) { %>
                                                                    <a href="/user/form/<%= inc.id %>"
                                                                        class="btn btn-secondary btn-sm"
                                                                        title="Edit Laporan">✏️ Edit</a>
                                                                    <form method="POST"
                                                                        action="/user/final/<%= inc.id %>"
                                                                        onsubmit="return confirm('Finalisasi laporan ini? Anda tidak akan bisa mengeditnya lagi.')">
                                                                        <button type="submit"
                                                                            class="btn btn-primary btn-sm"
                                                                            style="background:var(--accent); border:none">🏁
                                                                            Final</button>
                                                                    </form>
                                                                    <% } else if (!inc.is_today && !inc.is_final) { %>
                                                                        <small class="text-muted">🔒 Terkunci (Beda
                                                                            Hari)</small>
                                                                        <% } else { %>
                                                                            <small class="text-muted">🔒 Terkunci
                                                                                (Final)</small>
                                                                            <% } %>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                    <% } %>
        </main>
    </div>
</body>

</html>