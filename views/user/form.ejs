<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <% if (typeof isDetail==='undefined' ) { var isDetail=false; } %>
        <title>
            <%= isDetail ? 'Detail Laporan IKP' : (incident ? 'Edit Laporan IKP' : 'Form Laporan IKP' ) %>
        </title>
        <link rel="stylesheet" href="/css/style.css">
        <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>
        <style>
            /* Style tambahan untuk lookup SIMGOS */
            .alert-success {
                background: rgba(40, 167, 69, 0.2);
                border: 1px solid #28a745;
                color: #28a745;
                padding: 0.75rem;
                border-radius: 8px;
                margin-bottom: 1rem;
            }

            .alert-error {
                background: rgba(220, 53, 69, 0.2);
                border: 1px solid #dc3545;
                color: #dc3545;
                padding: 0.75rem;
                border-radius: 8px;
                margin-bottom: 1rem;
            }

            .btn-primary {
                background: #0d6efd;
                color: white;
                border: none;
                padding: 0.5rem 1.5rem;
                border-radius: 8px;
                cursor: pointer;
                font-weight: 500;
                height: 42px;
            }

            .btn-primary:hover {
                background: #0b5ed7;
            }

            .btn-primary:disabled {
                opacity: 0.6;
                cursor: not-allowed;
            }

            .lookup-section {
                border-left: 4px solid #0d6efd;
                background: rgba(13, 110, 253, 0.05);
                margin-bottom: 2rem;
            }

            .lookup-header {
                color: #0d6efd;
            }

            .patient-card {
                background: rgba(13, 110, 253, 0.1);
                border-radius: 12px;
                padding: 1.5rem;
                margin-top: 1rem;
            }

            .patient-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
                gap: 1rem;
            }

            .patient-item {
                margin-bottom: 0.5rem;
            }

            .patient-label {
                font-size: 0.85rem;
                color: #4b5563;
                /* Darker gray for label */
                margin-bottom: 0.25rem;
                font-weight: 600;
            }

            .patient-value {
                font-weight: 500;
                color: #1e293b;
                /* Dark/Black color for value */
            }
        </style>
</head>

<body>
    <div class="app-wrapper">
        <aside class="sidebar">
            <div class="sidebar-logo">
                <div class="logo-icon">🏥</div>
                <div class="logo-text">
                    <h2>Laporan IKP</h2><span>Keselamatan Pasien</span>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section-label">Pelapor</div>
                <a href="/user/dashboard" class="nav-item"><span class="nav-icon">📊</span> Dashboard</a>
                <a href="/user/form" class="nav-item <%= !incident ? 'active' : '' %>"><span class="nav-icon">📝</span>
                    Buat Laporan</a>
                <a href="/user/riwayat" class="nav-item"><span class="nav-icon">🕐</span> Riwayat Laporan</a>
            </nav>
            <div class="sidebar-footer">
                <div class="user-avatar">
                    <%= user ? user.name[0].toUpperCase() : '?' %>
                </div>
                <div class="user-info">
                    <div class="name">
                        <%= user ? user.name : '-' %>
                    </div>
                    <div class="role">👤 Pelapor</div>
                </div>
                <a href="/auth/logout" style="margin-left:auto;color:var(--danger);text-decoration:none;">🚪</a>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <div>
                    <h1>
                        <%= isDetail ? 'Detail Laporan IKP' : (incident ? 'Edit Laporan IKP'
                            : 'Laporan Insiden Keselamatan Pasien' ) %>
                    </h1>
                    <p>
                        <%= isDetail ? 'Anda sedang melihat detail laporan yang sudah final atau terkunci.'
                            : 'Edit laporan atau isi formulir baru. Field bertanda * wajib diisi.' %>
                    </p>
                </div>
            </div>

            <div class="card animate-slideUp">
                <% if (error && error.length> 0) { %>
                    <div class="alert alert-error">
                        <%= error[0] %>
                    </div>
                <% } %>

                <% if (success && success.length> 0) { %>
                    <div class="alert alert-success">
                        <%= success[0] %>
                    </div>
                <% } %>

                <form method="POST" action="/user/form<%= incident ? '/' + incident.id : '' %>"
                    enctype="multipart/form-data" id="ikpForm">
                                <input type="hidden" name="submit_type" id="submit_type" value="draft">

                                <!-- ==================== SECTION LOOKUP SIMGOS ==================== -->
                                <div class="form-section lookup-section">
                                    <div class="form-section-header">
                                        <div class="section-num" style="background: #0d6efd;">🔍</div>
                                        <h2 class="lookup-header">Cari Data Pasien (SIMGOS Integration)</h2>
                                    </div>
                                    <div class="form-section-body">
                                        <div
                                            style="display: flex; gap: 1rem; align-items: flex-end; margin-bottom: 1.5rem;">
                                            <div style="flex: 1;">
                                                <label>Nomor Rekam Medik <span class="required">*</span></label>
                                                <input type="text" id="no_rekam_medik" class="form-control"
                                                    placeholder="Masukkan No. RM"
                                                    value="<%= patientData ? patientData.no_rekam_medik : '' %>">
                                            </div>
                                            <button type="button" id="lookupBtn" class="btn-primary" <%=isDetail
                                                ? 'disabled' : '' %>>
                                                <span id="lookupText">Cari Data</span>
                                                <span id="lookupSpinner" style="display: none;">⌛</span>
                                            </button>
                                        </div>

                                        <!-- Status Message -->
                                        <div id="lookupStatus" style="display: none;"></div>

                                        <!-- Patient Data Display -->
                                        <div id="patientDataDisplay" style="display: none;" class="patient-card">
                                            <h3 style="color: #0d6efd; margin-bottom: 1rem; font-size: 1.1rem;">
                                                <span>📋 Data Pasien Ditemukan</span>
                                            </h3>
                                            <div class="patient-grid">
                                                <div class="patient-item">
                                                    <div class="patient-label">Nama Pasien</div>
                                                    <div class="patient-value" id="display_nama">-</div>
                                                </div>
                                                <div class="patient-item">
                                                    <div class="patient-label">No. RM</div>
                                                    <div class="patient-value" id="display_no_rm">-</div>
                                                </div>
                                                <div class="patient-item">
                                                    <div class="patient-label">Tanggal Lahir</div>
                                                    <div class="patient-value" id="display_tgl_lahir">-</div>
                                                </div>
                                                <div class="patient-item">
                                                    <div class="patient-label">Kelompok Umur</div>
                                                    <div class="patient-value" id="display_kelompok_umur">-</div>
                                                </div>
                                                <div class="patient-item">
                                                    <div class="patient-label">Jenis Kelamin</div>
                                                    <div class="patient-value" id="display_jk">-</div>
                                                </div>
                                                <div class="patient-item">
                                                    <div class="patient-label">Ruangan</div>
                                                    <div class="patient-value" id="display_ruangan">-</div>
                                                </div>
                                                <div class="patient-item">
                                                    <div class="patient-label">Penanggung Biaya</div>
                                                    <div class="patient-value" id="display_penanggung">-</div>
                                                </div>
                                                <div class="patient-item">
                                                    <div class="patient-label">Tanggal Masuk</div>
                                                    <div class="patient-value" id="display_tgl_masuk">-</div>
                                                </div>
                                                <div style="grid-column: span 2;">
                                                    <div class="patient-label">Alamat</div>
                                                    <div class="patient-value" id="display_alamat">-</div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Hidden inputs untuk menyimpan data pasien -->
                                        <input type="hidden" id="patient_nama" name="patient_nama"
                                            value="<%= patientData ? patientData.nama_pasien : '' %>">
                                        <input type="hidden" id="patient_no_rm" name="patient_no_rm"
                                            value="<%= patientData ? patientData.no_rekam_medik : '' %>">
                                        <input type="hidden" id="patient_tgl_lahir" name="patient_tgl_lahir"
                                            value="<%= patientData ? patientData.tanggal_lahir : '' %>">
                                        <input type="hidden" id="patient_kelompok_umur" name="patient_kelompok_umur"
                                            value="<%= patientData ? patientData.kelompok_umur : '' %>">
                                        <input type="hidden" id="patient_jk" name="patient_jk"
                                            value="<%= patientData ? patientData.jenis_kelamin : '' %>">
                                        <input type="hidden" id="patient_alamat" name="patient_alamat"
                                            value="<%= patientData ? patientData.alamat : '' %>">
                                        <input type="hidden" id="patient_ruangan" name="patient_ruangan"
                                            value="<%= patientData ? patientData.ruangan : '' %>">
                                        <input type="hidden" id="patient_penanggung_biaya"
                                            name="patient_penanggung_biaya"
                                            value="<%= patientData ? patientData.penanggung_biaya : '' %>">
                                        <input type="hidden" id="patient_tanggal_masuk" name="patient_tanggal_masuk"
                                            value="<%= patientData ? patientData.tanggal_masuk : '' %>">
                                    </div>
                                </div>
                                <!-- ==================== END LOOKUP SIMGOS ==================== -->

                                <!-- Section 1: Rincian Kejadian -->
                                <div class="form-section">
                                    <div class="form-section-header">
                                        <div class="section-num">1</div>
                                        <h2>Rincian Kejadian</h2>
                                    </div>
                                    <div class="form-section-body">
                                        <div class="form-grid">
                                            <% let tglVal='' ; if (incident && incident.tanggal_insiden) { try { let
                                                d=new Date(incident.tanggal_insiden);
                                                tglVal=d.toISOString().split('T')[0]; } catch(e) { tglVal='' ; } } %>
                                                <div class="form-group">
                                                    <label>Tanggal Insiden <span class="required">*</span></label>
                                                    <input type="date" name="tanggal_insiden" class="form-control"
                                                        value="<%= tglVal %>" required <%=isDetail ? 'disabled' : '' %>>
                                                </div>
                                                <div class="form-group">
                                                    <label>Waktu Insiden <span class="required">*</span></label>
                                                    <input type="time" name="waktu_insiden" class="form-control"
                                                        value="<%= incident ? incident.waktu_insiden : '' %>" required
                                                        <%=isDetail ? 'disabled' : '' %>>
                                                </div>
                                                <div class="form-group form-col-full">
                                                    <label>Insiden <span class="required">*</span></label>
                                                    <input type="text" name="insiden" class="form-control"
                                                        value="<%= incident ? incident.insiden : '' %>" required
                                                        <%=isDetail ? 'disabled' : '' %>>
                                                </div>
                                                <div class="form-group form-col-full">
                                                    <label>Kronologis Insiden <span class="required">*</span></label>
                                                    <textarea name="kronologis" class="form-control" rows="4" required
                                                        <%=isDetail ? 'disabled' : ''
                                                        %>><%= incident ? incident.kronologis : '' %></textarea>
                                                </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Section 2: Jenis Insiden -->
                                <div class="form-section">
                                    <div class="form-section-header">
                                        <div class="section-num">2</div>
                                        <h2>Jenis Insiden <span class="required">*</span></h2>
                                    </div>
                                    <div class="form-section-body">
                                        <div class="radio-group">
                                            <label class="radio-item">
                                                <input type="radio" name="jenis_insiden" value="KNC" <%=(incident &&
                                                    incident.jenis_insiden==='KNC' ) ? 'checked' : '' %> required <%=
                                                    isDetail ? 'disabled' : '' %>>
                                                    <span><strong>KNC</strong> - Kejadian Nyaris Cedera</span>
                                            </label>
                                            <label class="radio-item">
                                                <input type="radio" name="jenis_insiden" value="KTC" <%=(incident &&
                                                    incident.jenis_insiden==='KTC' ) ? 'checked' : '' %> required <%=
                                                    isDetail ? 'disabled' : '' %>>
                                                    <span><strong>KTC</strong> - Kejadian Tidak Cedera</span>
                                            </label>
                                            <label class="radio-item">
                                                <input type="radio" name="jenis_insiden" value="KPC" <%=(incident &&
                                                    incident.jenis_insiden==='KPC' ) ? 'checked' : '' %> required <%=
                                                    isDetail ? 'disabled' : '' %>>
                                                    <span><strong>KPC</strong> - Kejadian Potensial Cedera</span>
                                            </label>
                                            <label class="radio-item">
                                                <input type="radio" name="jenis_insiden" value="KTD" <%=(incident &&
                                                    incident.jenis_insiden==='KTD' ) ? 'checked' : '' %> required <%=
                                                    isDetail ? 'disabled' : '' %>>
                                                    <span><strong>KTD</strong> - Kejadian Tidak Diharapkan</span>
                                            </label>
                                            <label class="radio-item">
                                                <input type="radio" name="jenis_insiden" value="SENTINEL" <%=(incident
                                                    && incident.jenis_insiden==='SENTINEL' ) ? 'checked' : '' %>
                                                required <%= isDetail ? 'disabled' : '' %>>
                                                    <span><strong>SENTINEL</strong> - Kejadian Sentinel</span>
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <!-- Section 3: Pelapor & Objek Insiden -->
                                <div class="form-section">
                                    <div class="form-section-header">
                                        <div class="section-num">3</div>
                                        <h2>Pelapor & Objek Insiden</h2>
                                    </div>
                                    <div class="form-section-body">
                                        <div class="form-grid">
                                            <div class="form-group">
                                                <label>Orang Pertama Melaporkan <span class="required">*</span></label>
                                                <div class="radio-group">
                                                    <label class="radio-item">
                                                        <input type="radio" name="pelapor_pertama"
                                                            value="Karyawan (Dokter/Perawat/Petugas)" <%=(incident &&
                                                            incident.pelapor_pertama==='Karyawan (Dokter/Perawat/Petugas)'
                                                            ) ? 'checked' : '' %> required <%= isDetail ? 'disabled'
                                                            : '' %>>
                                                            <span>Karyawan (Dokter/Perawat/Petugas)</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="pelapor_pertama" value="Pasien"
                                                            <%=(incident && incident.pelapor_pertama==='Pasien' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Pasien</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="pelapor_pertama"
                                                            value="Keluarga/Pendamping" <%=(incident &&
                                                            incident.pelapor_pertama==='Keluarga/Pendamping' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Keluarga/Pendamping</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="pelapor_pertama" value="Pengunjung"
                                                            <%=(incident && incident.pelapor_pertama==='Pengunjung' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Pengunjung</span>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label>Insiden Terjadi Pada <span class="required">*</span></label>
                                                <div class="radio-group">
                                                    <label class="radio-item">
                                                        <input type="radio" name="insiden_terjadi_pada" value="Pasien"
                                                            <%=(incident && incident.insiden_terjadi_pada==='Pasien' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Pasien</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="insiden_terjadi_pada" value="Lainnya"
                                                            id="terjadi-lainnya-radio" <%=(incident &&
                                                            incident.insiden_terjadi_pada==='Lainnya' ) ? 'checked' : ''
                                                            %>
                                                        <%= isDetail ? 'disabled' : '' %>>
                                                            <span>Lain-lain</span>
                                                    </label>
                                                </div>
                                                <input type="text" name="insiden_terjadi_lainnya"
                                                    id="terjadi_lainnya_input" class="form-control mt-1"
                                                    value="<%= incident ? incident.insiden_terjadi_lainnya || '' : '' %>"
                                                    <%=isDetail ? 'disabled' : '' %>>
                                            </div>
                                            <div class="form-group">
                                                <label>Menyangkut Pasien <span class="required">*</span></label>
                                                <div class="radio-group">
                                                    <label class="radio-item">
                                                        <input type="radio" name="menyangkut_pasien"
                                                            value="Pasien Rawat Inap" <%=(incident &&
                                                            incident.menyangkut_pasien==='Pasien Rawat Inap' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Pasien Rawat Inap</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="menyangkut_pasien"
                                                            value="Pasien Rawat Jalan" <%=(incident &&
                                                            incident.menyangkut_pasien==='Pasien Rawat Jalan' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Pasien Rawat Jalan</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="menyangkut_pasien" value="Pasien UGD"
                                                            <%=(incident && incident.menyangkut_pasien==='Pasien UGD' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Pasien UGD</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="menyangkut_pasien" value="Lainnya"
                                                            id="menyangkut-lainnya-radio" <%=(incident &&
                                                            incident.menyangkut_pasien==='Lainnya' ) ? 'checked' : '' %>
                                                        <%= isDetail ? 'disabled' : '' %>>
                                                            <span>Lainnya</span>
                                                    </label>
                                                </div>
                                                <input type="text" name="menyangkut_lainnya"
                                                    id="menyangkut_lainnya_input" class="form-control mt-1"
                                                    value="<%= incident ? incident.menyangkut_lainnya || '' : '' %>"
                                                    <%=isDetail ? 'disabled' : '' %>>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Section 4: Lokasi & Spesialisasi -->
                                <div class="form-section">
                                    <div class="form-section-header">
                                        <div class="section-num">4</div>
                                        <h2>Lokasi & Spesialisasi</h2>
                                    </div>
                                    <div class="form-section-body">
                                        <div class="form-grid">
                                            <div class="form-group">
                                                <label>Tempat Insiden <span class="required">*</span></label>
                                                <input type="text" name="tempat_insiden" class="form-control"
                                                    value="<%= incident ? incident.tempat_insiden || '' : '' %>"
                                                    required <%=isDetail ? 'disabled' : '' %>>
                                            </div>
                                            <div class="form-group">
                                                <label>Unit / Departemen Terkait <span class="required">*</span></label>
                                                <input type="text" name="unit_terkait" class="form-control"
                                                    value="<%= incident ? incident.unit_terkait || '' : '' %>" required
                                                    <%=isDetail ? 'disabled' : '' %>>
                                            </div>
                                            <div class="form-group form-col-full">
                                                <label>Spesialisasi <span class="required">*</span></label>
                                                <select name="spesialisasi" class="form-control" id="spesialisasiSelect"
                                                    required <%=isDetail ? 'disabled' : '' %>>
                                                    <option value="">-- Pilih --</option>
                                                    <option value="Penyakit Dalam" <%=(incident &&
                                                        incident.spesialisasi==='Penyakit Dalam' ) ? 'selected' : '' %>
                                                        >Penyakit Dalam</option>
                                                    <option value="Bedah" <%=(incident &&
                                                        incident.spesialisasi==='Bedah' ) ? 'selected' : '' %>>Bedah
                                                    </option>
                                                    <option value="Anak" <%=(incident && incident.spesialisasi==='Anak'
                                                        ) ? 'selected' : '' %>>Anak</option>
                                                    <option value="Obstetri Gynekologi" <%=(incident &&
                                                        incident.spesialisasi==='Obstetri Gynekologi' ) ? 'selected'
                                                        : '' %>>Obstetri Gynekologi</option>
                                                    <option value="THT" <%=(incident && incident.spesialisasi==='THT' )
                                                        ? 'selected' : '' %>>THT</option>
                                                    <option value="Mata" <%=(incident && incident.spesialisasi==='Mata'
                                                        ) ? 'selected' : '' %>>Mata</option>
                                                    <option value="Saraf" <%=(incident &&
                                                        incident.spesialisasi==='Saraf' ) ? 'selected' : '' %>>Saraf
                                                    </option>
                                                    <option value="Anastesi" <%=(incident &&
                                                        incident.spesialisasi==='Anastesi' ) ? 'selected' : '' %>
                                                        >Anastesi</option>
                                                    <option value="Kulit dan Kelamin" <%=(incident &&
                                                        incident.spesialisasi==='Kulit dan Kelamin' ) ? 'selected' : ''
                                                        %>>Kulit dan Kelamin</option>
                                                    <option value="Jantung" <%=(incident &&
                                                        incident.spesialisasi==='Jantung' ) ? 'selected' : '' %>>Jantung
                                                    </option>
                                                    <option value="Paru" <%=(incident && incident.spesialisasi==='Paru'
                                                        ) ? 'selected' : '' %>>Paru</option>
                                                    <option value="Lainnya" <%=(incident &&
                                                        incident.spesialisasi==='Lainnya' ) ? 'selected' : '' %>>Lainnya
                                                    </option>
                                                </select>
                                                <input type="text" name="spesialisasi_lainnya" id="spesialisasi_lainnya"
                                                    class="form-control mt-1"
                                                    value="<%= incident ? incident.spesialisasi_lainnya || '' : '' %>"
                                                    <%=isDetail ? 'disabled' : '' %>>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Section 5: Akibat & Tindakan -->
                                <div class="form-section">
                                    <div class="form-section-header">
                                        <div class="section-num">5</div>
                                        <h2>Akibat & Tindakan</h2>
                                    </div>
                                    <div class="form-section-body">
                                        <div class="form-grid">
                                            <div class="form-group">
                                                <label>Akibat Insiden <span class="required">*</span></label>
                                                <div class="radio-group">
                                                    <label class="radio-item">
                                                        <input type="radio" name="akibat_insiden" value="Kematian"
                                                            <%=(incident && incident.akibat_insiden==='Kematian' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Kematian</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="akibat_insiden"
                                                            value="Cedera Irreversibel / Cedera Berat" <%=(incident &&
                                                            incident.akibat_insiden==='Cedera Irreversibel / Cedera Berat'
                                                            ) ? 'checked' : '' %> required <%= isDetail ? 'disabled'
                                                            : '' %>>
                                                            <span>Cedera Irreversibel / Cedera Berat</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="akibat_insiden"
                                                            value="Cedera Reversibel / Cedera Sedang" <%=(incident &&
                                                            incident.akibat_insiden==='Cedera Reversibel / Cedera Sedang'
                                                            ) ? 'checked' : '' %> required <%= isDetail ? 'disabled'
                                                            : '' %>>
                                                            <span>Cedera Reversibel / Cedera Sedang</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="akibat_insiden" value="Cedera Ringan"
                                                            <%=(incident && incident.akibat_insiden==='Cedera Ringan' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Cedera Ringan</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="akibat_insiden"
                                                            value="Tidak ada cedera" <%=(incident &&
                                                            incident.akibat_insiden==='Tidak ada cedera' ) ? 'checked'
                                                            : '' %> required <%= isDetail ? 'disabled' : '' %>>
                                                            <span>Tidak ada cedera</span>
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="form-group">
                                                <label>Tindakan Oleh <span class="required">*</span></label>
                                                <div class="radio-group">
                                                    <label class="radio-item">
                                                        <input type="radio" name="tindakan_oleh" value="Tim"
                                                            <%=(incident && incident.tindakan_oleh==='Tim' ) ? 'checked'
                                                            : '' %> required <%= isDetail ? 'disabled' : '' %>>
                                                            <span>Tim</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="tindakan_oleh" value="Dokter"
                                                            <%=(incident && incident.tindakan_oleh==='Dokter' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Dokter</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="tindakan_oleh" value="Perawat"
                                                            <%=(incident && incident.tindakan_oleh==='Perawat' )
                                                            ? 'checked' : '' %> required <%= isDetail ? 'disabled' : ''
                                                            %>>
                                                            <span>Perawat</span>
                                                    </label>
                                                    <label class="radio-item">
                                                        <input type="radio" name="tindakan_oleh" value="Lainnya"
                                                            id="tindakan-lainnya-radio" <%=(incident &&
                                                            incident.tindakan_oleh==='Lainnya' ) ? 'checked' : '' %>
                                                        <%= isDetail ? 'disabled' : '' %>>
                                                            <span>Lainnya</span>
                                                    </label>
                                                </div>
                                                <input type="text" name="tindakan_lainnya" id="tindakan_lainnya_input"
                                                    class="form-control mt-1"
                                                    value="<%= incident ? incident.tindakan_lainnya || '' : '' %>"
                                                    <%=isDetail ? 'disabled' : '' %>>
                                            </div>
                                            <div class="form-group form-col-full">
                                                <label>Tindakan Segera Setelah Kejadian <span
                                                        class="required">*</span></label>
                                                <textarea name="tindakan_segera" class="form-control" rows="3" required
                                                    <%=isDetail ? 'disabled' : ''
                                                    %>><%= incident ? incident.tindakan_segera || '' : '' %></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Section 6: Kejadian Serupa -->
                                <div class="form-section">
                                    <div class="form-section-header">
                                        <div class="section-num">6</div>
                                        <h2>Detail Kejadian Serupa</h2>
                                    </div>
                                    <div class="form-section-body">
                                        <div class="form-group">
                                            <label>Pernah terjadi di Unit lain? <span class="required">*</span></label>
                                            <div style="display: flex; gap: 1rem;">
                                                <label class="radio-item" style="flex:1">
                                                    <input type="radio" name="kejadian_serupa" value="ya" id="serupa-ya"
                                                        <%=(incident && incident.kejadian_serupa==1) ? 'checked' : '' %>
                                                    required <%= isDetail ? 'disabled' : '' %>>
                                                        <span>Ya</span>
                                                </label>
                                                <label class="radio-item" style="flex:1">
                                                    <input type="radio" name="kejadian_serupa" value="tidak"
                                                        id="serupa-tidak" <%=(incident && incident.kejadian_serupa==0)
                                                        ? 'checked' : '' %>
                                                    <%= isDetail ? 'disabled' : '' %>>
                                                        <span>Tidak</span>
                                                </label>
                                            </div>
                                        </div>
                                        <div id="detail-serupa-container" style="margin-top:1rem;"
                                             <%= (incident && (incident.kejadian_serupa == 1 || incident.detail_serupa)) ? '' : 'hidden' %>>
                                            <div class="form-group">
                                                <label>Detail Kejadian Serupa</label>
                                                <textarea name="detail_serupa" id="detail_serupa" class="form-control"
                                                    rows="3" <%=isDetail ? 'disabled' : ''
                                                    %>><%= incident ? incident.detail_serupa || '' : '' %></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Section 7: Pembuat Laporan -->
                                <div class="form-section">
                                    <div class="form-section-header">
                                        <div class="section-num">7</div>
                                        <h2>Pembuat Laporan</h2>
                                    </div>
                                    <div class="form-section-body">
                                        <div class="form-grid">
                                            <div class="form-group">
                                                <label>Upload Dokumen Bukti Insiden<%= incident &&
                                                        incident.pembuat_laporan_file ? '(Berkas Ada)' : '' %></label>
                                                <% if (!isDetail) { %>
                                                    <input type="file" name="pembuat_laporan_file" class="form-control">
                                                <% } %>
                                                <% if (incident && incident.pembuat_laporan_file) { %>
                                                    <div style="margin-top: 0.5rem;">
                                                        <a href="/uploads/<%= incident.pembuat_laporan_file %>"
                                                            target="_blank" class="btn btn-secondary btn-sm"
                                                            style="text-decoration: none;">
                                                            📄 Lihat/Unduh Berkas Pelapor
                                                        </a>
                                                    </div>
                                                    <% } %>
                                            </div>
                                            <div class="form-group">
                                                <label>Grading Risiko <span class="required">*</span></label>
                                                <select name="grading_risiko" class="form-control" required <%=isDetail
                                                    ? 'disabled' : '' %>>
                                                    <option value="">-- Pilih --</option>
                                                    <option value="Biru" <%=(incident &&
                                                        incident.grading_risiko==='Biru' ) ? 'selected' : '' %>>Biru
                                                    </option>
                                                    <option value="Hijau" <%=(incident &&
                                                        incident.grading_risiko==='Hijau' ) ? 'selected' : '' %>>Hijau
                                                    </option>
                                                    <option value="Kuning" <%=(incident &&
                                                        incident.grading_risiko==='Kuning' ) ? 'selected' : '' %>>Kuning
                                                    </option>
                                                    <option value="Merah" <%=(incident &&
                                                        incident.grading_risiko==='Merah' ) ? 'selected' : '' %>>Merah
                                                    </option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="form-group form-col-full" style="margin-top: 2rem;">
                                            <label>Tanda Tangan Digital <span class="required">*</span></label>
                                            <div>
                                                <canvas id="signature-pad" width="800" height="180"
                                                    style="border: 1px solid #ccc;"></canvas>
                                            </div>
                                            <div style="margin-top: 0.5rem;">
                                                <% if (!isDetail) { %>
                                                    <button type="button" class="btn btn-secondary btn-sm"
                                                        id="clearSignature">Hapus</button>
                                                    <% } %>
                                                        <span id="sig-status" class="text-muted"
                                                            style="font-size:0.78rem">
                                                            <%= (incident && incident.tanda_tangan)
                                                                ? 'Tanda tangan sudah ada' : 'Tanda tangan belum dibuat'
                                                                %>
                                                        </span>
                                            </div>
                                            <input type="hidden" name="tanda_tangan" id="tanda_tangan_data">
                                        </div>
                                    </div>
                            </div>

                            <div style="display:flex; gap:1rem; justify-content:flex-end; margin-top:2rem;">
                                <a href="/user/riwayat" class="btn btn-secondary">Kembali</a>
                                <% if (!isDetail) { %>
                                    <button type="button" class="btn btn-secondary" id="saveDraft">Simpan Draft</button>
                                    <button type="button" class="btn btn-primary btn-lg" id="submitFinal">Kirim Final</button>
                                <% } %>
                            </div>
                        </form>
                    </div> <!-- End Card -->
                </main>
            </div> <!-- End App Wrapper -->

    <!-- Safely pass data to JS via script tags instead of attributes -->
    <script id="app-config" type="application/json">
        {
            "incidentExists": <%= incident ? 'true' : 'false' %>,
            "hasTandaTangan": <%= incident && incident.tanda_tangan ? 'true' : 'false' %>,
            "terjadiValue": "<%= incident ? (incident.insiden_terjadi_pada || '') : '' %>",
            "menyangkutValue": "<%= incident ? (incident.menyangkut_pasien || '') : '' %>",
            "tindakanValue": "<%= incident ? (incident.tindakan_oleh || '') : '' %>",
            "spesialisasiValue": "<%= incident ? (incident.spesialisasi || '') : '' %>",
            "serupaValue": <%= incident && incident.kejadian_serupa == 1 ? 'true' : 'false' %>,
            "isDetail": <%= isDetail ? 'true' : 'false' %>
        }
    </script>
    <script id="patient-data-json" type="application/json">
        <%- JSON.stringify(patientData || null) %>
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            console.log('IKP Form Script Initializing...');
            
            let config = {};
            let patientData = null;
            
            try {
                config = JSON.parse(document.getElementById('app-config').textContent);
                patientData = JSON.parse(document.getElementById('patient-data-json').textContent);
            } catch (e) {
                console.error('Error parsing config data:', e);
            }

            const isNew = !config.incidentExists;
            const isDetail = config.isDetail;
            const hasTandaTangan = config.hasTandaTangan;
            const terjadiValue = config.terjadiValue || '';
            const menyangkutValue = config.menyangkutValue || '';
            const tindakanValue = config.tindakanValue || '';
            const spesialisasiValue = config.spesialisasiValue || '';
            const serupaValue = config.serupaValue;

            // Initialize Signature Pad
            const canvas = document.getElementById('signature-pad');
            let signaturePad = null;

            try {
                if (canvas && typeof SignaturePad !== 'undefined') {
                    signaturePad = new SignaturePad(canvas, {
                        backgroundColor: 'rgba(17, 24, 39, 1)', // Dark gray background
                        penColor: '#14b8a6' // Teal/Mint pen
                    });
                    
                    const signatureData = `<%- incident ? incident.tanda_tangan : '' %>`;
                    if (signatureData) {
                        signaturePad.fromDataURL(signatureData);
                    }
                    
                    if (isDetail) signaturePad.off();
                }
            } catch (e) {
                console.error('SignaturePad initialization failed:', e);
            }

            // Clear signature
            document.getElementById('clearSignature')?.addEventListener('click', function () {
                if (signaturePad) {
                    signaturePad.clear();
                    document.getElementById('sig-status').textContent = 'Tanda tangan dihapus';
                }
            });

            // ============ LOOKUP SIMGOS FUNCTIONALITY ============
            const lookupBtn = document.getElementById('lookupBtn');
            const noRMInput = document.getElementById('no_rekam_medik');
            const lookupStatus = document.getElementById('lookupStatus');
            const patientDisplay = document.getElementById('patientDataDisplay');
            const lookupText = document.getElementById('lookupText');
            const lookupSpinner = document.getElementById('lookupSpinner');

            function showLookupStatus(type, message) {
                lookupStatus.style.display = 'block';
                lookupStatus.className = '';
                lookupStatus.classList.add(type === 'success' ? 'alert-success' : 'alert-error');
                lookupStatus.innerHTML = message;

                if (type === 'success') {
                    setTimeout(() => {
                        lookupStatus.style.display = 'none';
                    }, 3000);
                }
            }

            function displayPatientData(data) {
                console.log('[DEBUG] Displaying patient data:', data);
                document.getElementById('display_nama').textContent = data.nama_pasien || data.nama || '-';
                document.getElementById('display_no_rm').textContent = data.no_rekam_medik || data.no_rm || '-';
                const tglLahir = data.tanggal_lahir || '';
                document.getElementById('display_tgl_lahir').textContent = tglLahir ? new Date(tglLahir).toLocaleDateString('id-ID') : '-';
                document.getElementById('display_kelompok_umur').textContent = data.kelompok_umur || '-';
                
                let jkText = '-';
                const jk = data.jenis_kelamin || '';
                if (jk === 'L' || jk === 'Laki-laki') jkText = 'Laki-laki';
                else if (jk === 'P' || jk === 'Perempuan') jkText = 'Perempuan';
                document.getElementById('display_jk').textContent = jkText;

                document.getElementById('display_ruangan').textContent = data.ruangan || '-';
                document.getElementById('display_penanggung').textContent = data.penanggung_biaya || '-';
                const tglMasuk = data.tanggal_masuk || '';
                document.getElementById('display_tgl_masuk').textContent = tglMasuk ? new Date(tglMasuk).toLocaleDateString('id-ID') : '-';
                document.getElementById('display_alamat').textContent = data.alamat || '-';

                // Set hidden inputs with normalized values
                document.getElementById('patient_nama').value = data.nama_pasien || data.nama || '';
                document.getElementById('patient_no_rm').value = data.no_rekam_medik || data.no_rm || '';
                document.getElementById('patient_tgl_lahir').value = tglLahir;
                document.getElementById('patient_kelompok_umur').value = data.kelompok_umur || '';
                document.getElementById('patient_jk').value = jkText; // Save full string to match ENUM
                document.getElementById('patient_alamat').value = data.alamat || '';
                document.getElementById('patient_ruangan').value = data.ruangan || '';
                document.getElementById('patient_penanggung_biaya').value = data.penanggung_biaya || '';
                document.getElementById('patient_tanggal_masuk').value = tglMasuk;

                patientDisplay.style.display = 'block';
            }

            if (lookupBtn) {
                lookupBtn.addEventListener('click', async function () {
                    const noRM = noRMInput.value.trim();
                    if (!noRM) {
                        showLookupStatus('error', '❌ Nomor Rekam Medik harus diisi');
                        return;
                    }

                    lookupText.style.display = 'none';
                    lookupSpinner.style.display = 'inline';
                    lookupBtn.disabled = true;
                    lookupStatus.style.display = 'none';

                    try {
                        const response = await fetch('/user/lookup-patient', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ no_rekam_medik: noRM })
                        });

                        const result = await response.json();
                        if (result.success) {
                            displayPatientData(result.data);
                            showLookupStatus('success', '✅ Data pasien berhasil ditemukan');
                        } else {
                            patientDisplay.style.display = 'none';
                            showLookupStatus('error', '❌ ' + (result.message || 'Data pasien tidak ditemukan'));
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        showLookupStatus('error', '❌ Terjadi kesalahan saat lookup data');
                    } finally {
                        lookupText.style.display = 'inline';
                        lookupSpinner.style.display = 'none';
                        lookupBtn.disabled = false;
                    }
                });
            }

            if (noRMInput) {
                noRMInput.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        lookupBtn.click();
                    }
                });
            }

            if (patientData) {
                displayPatientData(patientData);
            }

            // Function to show/hide Lainnya inputs
            function toggleLainnyaInput(radioName, inputId, condition) {
                const input = document.getElementById(inputId);
                if (!input) return;

                const radios = document.querySelectorAll(`input[name="${radioName}"]`);
                radios.forEach(radio => {
                    radio.addEventListener('change', function () {
                        input.style.display = this.value === 'Lainnya' && this.checked ? 'block' : 'none';
                        if (this.value !== 'Lainnya') {
                            input.value = '';
                        }
                    });
                });

                // Set initial state
                const checkedRadio = document.querySelector(`input[name="${radioName}"]:checked`);
                if (checkedRadio) {
                    input.style.display = checkedRadio.value === 'Lainnya' ? 'block' : 'none';
                } else if (condition) {
                    input.style.display = 'block';
                } else {
                    input.style.display = 'none';
                }
            }

            toggleLainnyaInput('insiden_terjadi_pada', 'terjadi_lainnya_input', terjadiValue === 'Lainnya');
            toggleLainnyaInput('menyangkut_pasien', 'menyangkut_lainnya_input', menyangkutValue === 'Lainnya');
            toggleLainnyaInput('tindakan_oleh', 'tindakan_lainnya_input', tindakanValue === 'Lainnya');

            const spesialisasiSelect = document.getElementById('spesialisasiSelect');
            const spesialisasiInput = document.getElementById('spesialisasi_lainnya');

            if (spesialisasiSelect && spesialisasiInput) {
                spesialisasiSelect.addEventListener('change', function () {
                    spesialisasiInput.style.display = this.value === 'Lainnya' ? 'block' : 'none';
                    if (this.value !== 'Lainnya') {
                        spesialisasiInput.value = '';
                    }
                });
                if (spesialisasiValue === 'Lainnya') {
                    spesialisasiInput.style.display = 'block';
                } else {
                    spesialisasiInput.style.display = 'none';
                }
            }

            const serupaYa = document.getElementById('serupa-ya');
            const serupaTidak = document.getElementById('serupa-tidak');
            const detailContainer = document.getElementById('detail-serupa-container');
            const detailSerupa = document.getElementById('detail_serupa');

            if (serupaYa && serupaTidak && detailContainer) {
                serupaYa.addEventListener('change', function () {
                    detailContainer.style.display = 'block';
                });
                serupaTidak.addEventListener('change', function () {
                    detailContainer.style.display = 'none';
                    if (detailSerupa) detailSerupa.value = '';
                });

                if (serupaValue || (detailSerupa && detailSerupa.value.trim() !== "")) {
                    detailContainer.style.display = 'block';
                } else {
                    detailContainer.style.display = 'none';
                }
            }

            if (isNew) {
                const tglInput = document.querySelector('input[name="tanggal_insiden"]');
                if (tglInput && !tglInput.value) {
                    const today = new Date();
                    const yyyy = today.getFullYear();
                    const mm = String(today.getMonth() + 1).padStart(2, '0');
                    const dd = String(today.getDate()).padStart(2, '0');
                    tglInput.value = yyyy + '-' + mm + '-' + dd;
                }
            }

            // Submit handlers
            document.getElementById('saveDraft')?.addEventListener('click', function () {
                console.log('Save Draft clicked');
                document.getElementById('submit_type').value = 'draft';
                submitForm();
            });

            document.getElementById('submitFinal')?.addEventListener('click', function () {
                console.log('Submit Final clicked');
                if (!confirm('Yakin ingin mengirim laporan FINAL? Setelah ini laporan tidak dapat diedit lagi.')) {
                    return;
                }
                document.getElementById('submit_type').value = 'final';
                submitForm();
            });

            function submitForm() {
                console.log('Submitting form...');
                if (isNew) {
                    const patientRM = document.getElementById('patient_no_rm').value;
                    if (!patientRM) {
                        alert('Harap cari data pasien terlebih dahulu menggunakan fitur SIMGOS.');
                        document.getElementById('no_rekam_medik').focus();
                        return;
                    }
                }

                if (isNew && signaturePad && signaturePad.isEmpty()) {
                    alert('Harap tambahkan tanda tangan digital.');
                    return;
                }

                if (signaturePad && !signaturePad.isEmpty()) {
                    document.getElementById('tanda_tangan_data').value = signaturePad.toDataURL();
                } else if (!hasTandaTangan) {
                    alert('Harap tambahkan tanda tangan digital.');
                    return;
                }

                console.log('Form validated, submitting now...');
                document.getElementById('ikpForm').submit();
            }
        });
    </script>
</body>

</html>